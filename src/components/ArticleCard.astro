---
interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
}

const { title, description, href, date } = Astro.props;
---

<a href={href} class="group block rounded-xl border border-stone-200 bg-white p-6 transition-all hover:border-teal-300 hover:shadow-md">
  <time datetime={date} class="text-xs text-slate-400">
    {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
  </time>
  <h3 class="mt-2 font-serif text-lg font-bold text-slate-900 group-hover:text-teal-700 transition-colors">
    {title}
  </h3>
  <p class="mt-2 text-sm text-slate-500 line-clamp-3">{description}</p>
  <span class="mt-4 inline-block text-sm font-medium text-teal-700 group-hover:underline">
    Read article &rarr;
  </span>
</a>
