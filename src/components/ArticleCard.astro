---
interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
}

const { title, description, href, date } = Astro.props;
---

<a href={href} class="group block py-7" style={`border-bottom: 1px solid hsl(185 8% 12%);`}>
  <div class="flex items-baseline justify-between gap-4 mb-2">
    <h3 class="font-serif text-lg font-bold transition-colors" style="color: hsl(170 5% 90%);" >
      <span class="group-hover:underline decoration-2 underline-offset-4" style="text-decoration-color: hsl(170 60% 50%);">
        {title}
      </span>
    </h3>
    <time datetime={date} class="shrink-0 text-xs" style="color: hsl(170 5% 35%);">
      {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
    </time>
  </div>
  <p class="text-sm leading-relaxed" style="color: hsl(170 5% 50%);">
    {description}
  </p>
</a>
