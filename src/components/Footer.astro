---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-stone-200 bg-stone-50 py-12">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid gap-8 sm:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="font-serif text-lg font-bold text-slate-900">MoreBetterLabs</a>
        <p class="mt-2 text-sm text-slate-500">
          Learning design research and practice by Abe Crystal, PhD.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold text-slate-700 mb-3">Explore</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/learning-design/" class="text-slate-500 hover:text-teal-700 transition-colors">Learning Design</a></li>
          <li><a href="/about/" class="text-slate-500 hover:text-teal-700 transition-colors">About</a></li>
          <li><a href="/projects/" class="text-slate-500 hover:text-teal-700 transition-colors">Projects</a></li>
        </ul>
      </div>

      <!-- Ruzuku -->
      <div>
        <h3 class="text-sm font-semibold text-slate-700 mb-3">From MoreBetterLabs</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="https://www.ruzuku.com" class="text-slate-500 hover:text-teal-700 transition-colors" rel="noopener">Ruzuku &mdash; Online Course Platform</a></li>
          <li><a href="https://www.ruzuku.com/learn" class="text-slate-500 hover:text-teal-700 transition-colors" rel="noopener">Course Creation Resources</a></li>
          <li><a href="https://www.amazon.com/Business-Courses-Abe-Crystal/dp/1737374218" class="text-slate-500 hover:text-teal-700 transition-colors" rel="noopener noreferrer">The Business of Courses</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-stone-200 text-xs text-slate-400">
      &copy; {currentYear} MoreBetterLabs. All rights reserved.
    </div>
  </div>
</footer>
