---
const navItems = [
  { label: 'Learning Design', href: '/learning-design/' },
  { label: 'About', href: '/about/' },
  { label: 'Projects', href: '/projects/' },
];
---

<header class="border-b border-stone-200 bg-white">
  <nav class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between" aria-label="Main navigation">
    <a href="/" class="flex items-center gap-2 text-slate-900 hover:text-teal-700 transition-colors">
      <svg width="28" height="28" viewBox="0 0 32 32" class="shrink-0">
        <rect width="32" height="32" rx="6" fill="currentColor"/>
        <text x="16" y="22" font-family="Georgia, serif" font-size="18" font-weight="bold" fill="white" text-anchor="middle">M</text>
      </svg>
      <span class="font-serif text-lg font-bold">MoreBetterLabs</span>
    </a>

    <ul class="flex items-center gap-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-sm text-slate-600 hover:text-teal-700 transition-colors"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
