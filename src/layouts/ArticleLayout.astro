---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate?: string;
  keywords?: string[];
  slug: string;
}

const { title, description, publishDate, updatedDate, keywords = [], slug } = Astro.props;
const siteUrl = 'https://morebetterlabs.com';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Learning Design', href: '/learning-design/' },
  { label: title },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: 'Abe Crystal',
    honorificSuffix: 'PhD',
    jobTitle: 'Learning Design Researcher',
    url: `${siteUrl}/about`,
    sameAs: [
      'https://www.ruzuku.com/about/abe-crystal',
      'https://www.researchgate.net/scientific-contributions/Abe-Crystal-10858663',
    ],
  },
  datePublished: publishDate,
  dateModified: updatedDate || publishDate,
  publisher: {
    '@type': 'Organization',
    name: 'MoreBetterLabs',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/learning-design/${slug}/`,
  },
  keywords: keywords.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs
    .filter((b) => b.href)
    .map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.label,
      item: `${siteUrl}${b.href}`,
    })),
};

// Get related articles (all except current)
const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter((a) => a.slug !== slug)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);
---

<BaseLayout
  title={`${title} | MoreBetterLabs`}
  description={description}
  canonical={`/learning-design/${slug}/`}
  schema={[articleSchema, breadcrumbSchema]}
>
  <article>
    <!-- Hero -->
    <header class="pt-8 pb-12 sm:pt-12 sm:pb-16">
      <div class="max-w-[680px] mx-auto px-5">
        <Breadcrumbs items={breadcrumbs} />
        <h1 class="font-serif text-3xl sm:text-4xl font-bold leading-tight mt-6 mb-5" style="color: hsl(170 5% 95%);">
          {title}
        </h1>
        <p class="text-base leading-relaxed mb-6" style="color: hsl(170 5% 50%);">
          {description}
        </p>
        <div class="flex items-center gap-3 text-sm" style="color: hsl(170 5% 40%);">
          <span class="font-medium" style="color: hsl(170 5% 65%);">Abe Crystal, PhD</span>
          <span aria-hidden="true">&middot;</span>
          <time datetime={publishDate}>
            {new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>
                Updated <time datetime={updatedDate}>
                  {new Date(updatedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Divider -->
    <div class="max-w-[680px] mx-auto px-5">
      <div style={`height: 1px; background: hsl(185 8% 14%);`}></div>
    </div>

    <!-- Content -->
    <div class="max-w-[680px] mx-auto px-5 py-12 sm:py-16">
      <div class="prose-mbl">
        <slot />
      </div>
    </div>
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="py-16" style={`border-top: 1px solid hsl(185 8% 12%);`}>
      <div class="max-w-[680px] mx-auto px-5">
        <h2 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: hsl(170 60% 50%);">
          Keep Reading
        </h2>
        <div>
          {relatedArticles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/learning-design/${article.slug}/`}
              date={article.data.publishDate}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
