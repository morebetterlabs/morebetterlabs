---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorBox from '../components/AuthorBox.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate?: string;
  keywords?: string[];
  faqs?: FAQ[];
  slug: string;
}

const { title, description, publishDate, updatedDate, keywords = [], faqs = [], slug } = Astro.props;
const siteUrl = 'https://morebetterlabs.com';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Learning Design', href: '/learning-design/' },
  { label: title },
];

// Estimate word count from rendered content (fallback to 1500)
const wordCount = 1500;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: 'Abe Crystal',
    honorificSuffix: 'PhD',
    jobTitle: 'Learning Design Researcher',
    url: `${siteUrl}/about`,
    sameAs: [
      'https://www.ruzuku.com/about/abe-crystal',
      'https://www.researchgate.net/scientific-contributions/Abe-Crystal-10858663',
    ],
    alumniOf: [
      { '@type': 'CollegeOrUniversity', name: 'University of North Carolina at Chapel Hill' },
      { '@type': 'CollegeOrUniversity', name: 'Princeton University' },
    ],
  },
  datePublished: publishDate,
  dateModified: updatedDate || publishDate,
  publisher: {
    '@type': 'Organization',
    name: 'MoreBetterLabs',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/learning-design/${slug}/`,
  },
  keywords: keywords.join(', '),
  wordCount,
  inLanguage: 'en-US',
  educationalLevel: 'Professional',
  about: {
    '@type': 'Thing',
    name: 'Learning Design',
    sameAs: 'https://en.wikipedia.org/wiki/Instructional_design',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs
    .filter((b) => b.href)
    .map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.label,
      item: `${siteUrl}${b.href}`,
    })),
};

// FAQ schema (only if FAQs are provided)
const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;

const schemas = [articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];

// Get related articles (all except current)
const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter((a) => a.slug !== slug)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);
---

<BaseLayout
  title={`${title} | MoreBetterLabs`}
  description={description}
  canonical={`/learning-design/${slug}/`}
  schema={schemas}
  keywords={keywords}
>
  <article>
    <!-- Hero -->
    <header class="pt-8 pb-12 sm:pt-12 sm:pb-16">
      <div class="max-w-[680px] mx-auto px-5">
        <Breadcrumbs items={breadcrumbs} />
        <h1 class="font-serif text-3xl sm:text-4xl font-bold leading-tight mt-6 mb-5" style="color: hsl(170 5% 95%);">
          {title}
        </h1>
        <p class="text-base leading-relaxed mb-6" style="color: hsl(170 5% 50%);">
          {description}
        </p>
        <div class="flex items-center gap-3 text-sm" style="color: hsl(170 5% 40%);">
          <span class="font-medium" style="color: hsl(170 5% 65%);">Abe Crystal, PhD</span>
          <span aria-hidden="true">&middot;</span>
          <time datetime={publishDate}>
            {new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>
                Updated <time datetime={updatedDate}>
                  {new Date(updatedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Divider -->
    <div class="max-w-[680px] mx-auto px-5">
      <div style={`height: 1px; background: hsl(185 8% 14%);`}></div>
    </div>

    <!-- Content -->
    <div class="max-w-[680px] mx-auto px-5 py-12 sm:py-16">
      <div class="prose-mbl">
        <slot />
      </div>

      <!-- FAQ Section -->
      {faqs.length > 0 && (
        <section class="faq-section" style={`margin-top: 3rem; padding-top: 2rem; border-top: 1px solid hsl(185 8% 14%);`}>
          <h2 style="color: hsl(170 5% 90%); font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; font-family: var(--font-serif);">
            Frequently Asked Questions
          </h2>
          {faqs.map((faq) => (
            <details class="faq-item" style={`
              margin-bottom: 1rem;
              padding: 1rem 1.25rem;
              border-radius: 0.5rem;
              background: hsl(185 10% 8%);
              border: 1px solid hsl(185 8% 14%);
            `}>
              <summary style={`
                color: hsl(170 5% 85%);
                font-weight: 600;
                cursor: pointer;
                font-size: 0.95rem;
                line-height: 1.5;
              `}>{faq.question}</summary>
              <p style={`
                color: hsl(170 5% 55%);
                margin-top: 0.75rem;
                font-size: 0.925rem;
                line-height: 1.7;
              `}>{faq.answer}</p>
            </details>
          ))}
        </section>
      )}

      <!-- Author Box -->
      <AuthorBox />
    </div>
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="py-16" style={`border-top: 1px solid hsl(185 8% 12%);`}>
      <div class="max-w-[680px] mx-auto px-5">
        <h2 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: hsl(170 60% 50%);">
          Keep Reading
        </h2>
        <div>
          {relatedArticles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/learning-design/${article.slug}/`}
              date={article.data.publishDate}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
