---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorBox from '../components/AuthorBox.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate?: string;
  keywords?: string[];
  faqs?: FAQ[];
  slug: string;
}

const { title, description, publishDate, updatedDate, keywords = [], faqs = [], slug } = Astro.props;
const siteUrl = 'https://morebetterlabs.com';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Learning Design', href: '/learning-design/' },
  { label: title },
];

// Estimate word count from rendered content (fallback to 1500)
const wordCount = 1500;

// Citation data per article (structured references for JSON-LD)
const citationsBySlug: Record<string, Array<{ name: string; author?: string; datePublished?: string; publisher?: string; url?: string }>> = {
  'the-two-traps-that-kill-online-courses': [
    { name: 'Active learning increases student performance in science, engineering, and mathematics', author: 'Scott Freeman, Sarah L. Eddy, Miles McDonough et al.', datePublished: '2014', publisher: 'Proceedings of the National Academy of Sciences' },
    { name: 'The expertise reversal effect', author: 'Slava Kalyuga, Paul Ayres, Paul Chandler, John Sweller', datePublished: '2003', publisher: 'Educational Psychologist' },
    { name: 'Cognitive load during problem solving: Effects on learning', author: 'John Sweller', datePublished: '1988', publisher: 'Cognitive Science' },
    { name: 'Understanding by Design', author: 'Grant Wiggins, Jay McTighe', datePublished: '2005', publisher: 'ASCD' },
  ],
  'why-online-course-completion-rates-are-low': [
    { name: 'The "what" and "why" of goal pursuits: Human needs and the self-determination of behavior', author: 'Edward L. Deci, Richard M. Ryan', datePublished: '2000', publisher: 'Psychological Inquiry' },
    { name: 'Active learning increases student performance in science, engineering, and mathematics', author: 'Scott Freeman, Sarah L. Eddy, Miles McDonough et al.', datePublished: '2014', publisher: 'Proceedings of the National Academy of Sciences' },
    { name: 'The power of feedback', author: 'John Hattie, Helen Timperley', datePublished: '2007', publisher: 'Review of Educational Research' },
    { name: 'Massive open online course completion rates revisited', author: 'Katy Jordan', datePublished: '2015', publisher: 'International Review of Research in Open and Distributed Learning' },
    { name: 'A brief social-belonging intervention improves academic and health outcomes of minority students', author: 'Gregory M. Walton, Geoffrey L. Cohen', datePublished: '2011', publisher: 'Science' },
    { name: 'Building a practically useful theory of goal setting and task motivation', author: 'Edwin A. Locke, Gary P. Latham', datePublished: '2002', publisher: 'American Psychologist' },
  ],
  'the-science-of-cohort-based-learning': [
    { name: 'Mind in society: The development of higher psychological processes', author: 'Lev S. Vygotsky', datePublished: '1978', publisher: 'Harvard University Press' },
    { name: 'Critical inquiry in a text-based environment: Computer conferencing in higher education', author: 'D. Randy Garrison, Terry Anderson, Walter Archer', datePublished: '2000', publisher: 'The Internet and Higher Education' },
    { name: 'Memory and metamemory considerations in the training of human beings', author: 'Robert A. Bjork', datePublished: '1994' },
    { name: 'Improving students\' learning with effective learning techniques', author: 'John Dunlosky, Katherine A. Rawson, Elizabeth J. Marsh et al.', datePublished: '2013', publisher: 'Psychological Science in the Public Interest' },
    { name: 'Commitment devices: Using initiatives to change behavior', author: 'Todd Rogers, Katherine L. Milkman, Kevin G. Volpp', datePublished: '2014', publisher: 'JAMA' },
  ],
  'adult-learning-principles-for-course-creators': [
    { name: 'The modern practice of adult education: From pedagogy to andragogy', author: 'Malcolm S. Knowles', datePublished: '1980', publisher: 'Cambridge Adult Education' },
    { name: 'Experiential learning: Experience as the source of learning and development', author: 'David A. Kolb', datePublished: '1984', publisher: 'Prentice-Hall' },
    { name: 'Andragogy and self-directed learning: Pillars of adult learning theory', author: 'Sharan B. Merriam', datePublished: '2001', publisher: 'New Directions for Adult and Continuing Education' },
    { name: 'Understanding by Design', author: 'Grant Wiggins, Jay McTighe', datePublished: '2005', publisher: 'ASCD' },
    { name: 'Improving students\' learning with effective learning techniques', author: 'John Dunlosky, Katherine A. Rawson, Elizabeth J. Marsh et al.', datePublished: '2013', publisher: 'Psychological Science in the Public Interest' },
  ],
  'the-minimum-viable-course': [
    { name: 'Cognitive load during problem solving: Effects on learning', author: 'John Sweller', datePublished: '1988', publisher: 'Cognitive Science' },
    { name: 'The magical number seven, plus or minus two', author: 'George A. Miller', datePublished: '1956', publisher: 'Psychological Review' },
    { name: 'Memory and metamemory considerations in the training of human beings', author: 'Robert A. Bjork', datePublished: '1994' },
  ],
  'how-to-define-measurable-outcomes': [
    { name: 'Understanding by Design', author: 'Grant Wiggins, Jay McTighe', datePublished: '2005', publisher: 'ASCD' },
    { name: 'The modern practice of adult education: From pedagogy to andragogy', author: 'Malcolm S. Knowles', datePublished: '1980', publisher: 'Cambridge Adult Education' },
  ],
  'the-learner-persona-method': [
    { name: 'The modern practice of adult education: From pedagogy to andragogy', author: 'Malcolm S. Knowles', datePublished: '1980', publisher: 'Cambridge Adult Education' },
  ],
  'why-your-first-course-should-be-imperfect': [
    { name: 'Prospect theory: An analysis of decision under risk', author: 'Daniel Kahneman, Amos Tversky', datePublished: '1979', publisher: 'Econometrica' },
    { name: 'Assessment and classroom learning', author: 'Paul Black, Dylan Wiliam', datePublished: '1998', publisher: 'Assessment in Education' },
  ],
  'inclusive-course-design': [
    { name: 'Universal design for learning: Theory and practice', author: 'Anne Meyer, David H. Rose, David Gordon', datePublished: '2014', publisher: 'CAST Professional Publishing' },
    { name: 'A review of research on universal design educational models', author: 'Kavita Rao, Min Wook Ok, Brian R. Bryant', datePublished: '2014', publisher: 'Remedial and Special Education' },
    { name: 'Cognitive load during problem solving: Effects on learning', author: 'John Sweller', datePublished: '1988', publisher: 'Cognitive Science' },
    { name: 'Mental representations: A dual coding approach', author: 'Allan Paivio', datePublished: '1986', publisher: 'Oxford University Press' },
  ],
  'designing-effective-feedback-in-online-courses': [
    { name: 'The power of feedback', author: 'John Hattie, Helen Timperley', datePublished: '2007', publisher: 'Review of Educational Research' },
    { name: 'Assessment and classroom learning', author: 'Paul Black, Dylan Wiliam', datePublished: '1998', publisher: 'Assessment in Education' },
  ],
  'community-as-pedagogy': [
    { name: 'Communities of practice: Learning, meaning, and identity', author: 'Etienne Wenger', datePublished: '1998', publisher: 'Cambridge University Press' },
    { name: 'Critical inquiry in a text-based environment: Computer conferencing in higher education', author: 'D. Randy Garrison, Terry Anderson, Walter Archer', datePublished: '2000', publisher: 'The Internet and Higher Education' },
    { name: 'Mind in society: The development of higher psychological processes', author: 'Lev S. Vygotsky', datePublished: '1978', publisher: 'Harvard University Press' },
  ],
  'the-psychology-of-course-pricing': [
    { name: 'Prospect theory: An analysis of decision under risk', author: 'Daniel Kahneman, Amos Tversky', datePublished: '1979', publisher: 'Econometrica' },
    { name: 'Predictably Irrational', author: 'Dan Ariely', datePublished: '2008', publisher: 'HarperCollins' },
  ],
  'designing-credible-certification-programs': [
    { name: 'Standards for Educational and Psychological Testing', author: 'American Educational Research Association, American Psychological Association, National Council on Measurement in Education', datePublished: '2014' },
  ],
};

const citations = citationsBySlug[slug] || [];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: 'Abe Crystal',
    honorificSuffix: 'PhD',
    jobTitle: 'Learning Design Researcher',
    url: `${siteUrl}/about`,
    sameAs: [
      'https://www.ruzuku.com/about/abe-crystal',
      'https://www.researchgate.net/scientific-contributions/Abe-Crystal-10858663',
    ],
    alumniOf: [
      { '@type': 'CollegeOrUniversity', name: 'University of North Carolina at Chapel Hill' },
      { '@type': 'CollegeOrUniversity', name: 'Princeton University' },
    ],
  },
  datePublished: publishDate,
  dateModified: updatedDate || publishDate,
  publisher: {
    '@type': 'Organization',
    name: 'MoreBetterLabs',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/learning-design/${slug}/`,
  },
  keywords: keywords.join(', '),
  wordCount,
  inLanguage: 'en-US',
  educationalLevel: 'Professional',
  about: {
    '@type': 'Thing',
    name: 'Learning Design',
    sameAs: 'https://en.wikipedia.org/wiki/Instructional_design',
  },
  ...(citations.length > 0 && {
    citation: citations.map((c) => ({
      '@type': 'CreativeWork',
      name: c.name,
      ...(c.author && { author: { '@type': 'Person', name: c.author } }),
      ...(c.datePublished && { datePublished: c.datePublished }),
      ...(c.publisher && { publisher: { '@type': 'Organization', name: c.publisher } }),
      ...(c.url && { url: c.url }),
    })),
  }),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs
    .filter((b) => b.href)
    .map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: b.label,
      item: `${siteUrl}${b.href}`,
    })),
};

// FAQ schema (only if FAQs are provided)
const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;

const schemas = [articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];

// Get related articles (all except current)
const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter((a) => a.slug !== slug)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);
---

<BaseLayout
  title={`${title} | MoreBetterLabs`}
  description={description}
  canonical={`/learning-design/${slug}/`}
  schema={schemas}
  keywords={keywords}
  ogImage={`/og/${slug}.svg`}
>
  <article>
    <!-- Hero -->
    <header class="pt-8 pb-12 sm:pt-12 sm:pb-16">
      <div class="max-w-[680px] mx-auto px-5">
        <Breadcrumbs items={breadcrumbs} />
        <h1 class="font-serif text-3xl sm:text-4xl font-bold leading-tight mt-6 mb-5" style="color: hsl(170 5% 95%);">
          {title}
        </h1>
        <p class="text-base leading-relaxed mb-6" style="color: hsl(170 5% 50%);">
          {description}
        </p>
        <div class="flex items-center gap-3 text-sm" style="color: hsl(170 5% 40%);">
          <span class="font-medium" style="color: hsl(170 5% 65%);">Abe Crystal, PhD</span>
          <span aria-hidden="true">&middot;</span>
          <time datetime={publishDate}>
            {new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>
                Updated <time datetime={updatedDate}>
                  {new Date(updatedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Divider -->
    <div class="max-w-[680px] mx-auto px-5">
      <div style={`height: 1px; background: hsl(185 8% 14%);`}></div>
    </div>

    <!-- Content -->
    <div class="max-w-[680px] mx-auto px-5 py-12 sm:py-16">
      <div class="prose-mbl">
        <slot />
      </div>

      <!-- FAQ Section -->
      {faqs.length > 0 && (
        <section class="faq-section" style={`margin-top: 3rem; padding-top: 2rem; border-top: 1px solid hsl(185 8% 14%);`}>
          <h2 style="color: hsl(170 5% 90%); font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; font-family: var(--font-serif);">
            Frequently Asked Questions
          </h2>
          {faqs.map((faq) => (
            <details class="faq-item" style={`
              margin-bottom: 1rem;
              padding: 1rem 1.25rem;
              border-radius: 0.5rem;
              background: hsl(185 10% 8%);
              border: 1px solid hsl(185 8% 14%);
            `}>
              <summary style={`
                color: hsl(170 5% 85%);
                font-weight: 600;
                cursor: pointer;
                font-size: 0.95rem;
                line-height: 1.5;
              `}>{faq.question}</summary>
              <p style={`
                color: hsl(170 5% 55%);
                margin-top: 0.75rem;
                font-size: 0.925rem;
                line-height: 1.7;
              `}>{faq.answer}</p>
            </details>
          ))}
        </section>
      )}

      <!-- Author Box -->
      <AuthorBox />
    </div>
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="py-16" style={`border-top: 1px solid hsl(185 8% 12%);`}>
      <div class="max-w-[680px] mx-auto px-5">
        <h2 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: hsl(170 60% 50%);">
          Keep Reading
        </h2>
        <div>
          {relatedArticles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/learning-design/${article.slug}/`}
              date={article.data.publishDate}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
