---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'MoreBetterLabs',
  url: 'https://morebetterlabs.com',
  description: 'Learning design research and practice by Abe Crystal, PhD',
};
---

<BaseLayout
  title="MoreBetterLabs — Learning Design Research & Practice"
  description="Research-backed insights on learning design by Abe Crystal, PhD. How to design online courses that actually work — grounded in learning science, tested in practice."
  canonical="/"
  schema={[websiteSchema]}
>
  <!-- Hero -->
  <section class="bg-stone-50 border-b border-stone-200 py-20 sm:py-28">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-sm font-medium text-teal-700 mb-4">MoreBetterLabs</p>
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-tight mb-6">
        Better Learning Design,<br/>Better Outcomes
      </h1>
      <p class="text-xl text-slate-500 leading-relaxed max-w-2xl mb-8">
        Research-backed insights on designing online learning experiences that actually work.
        By <a href="/about/" class="text-teal-700 underline decoration-teal-300 hover:decoration-teal-500">Abe Crystal, PhD</a> — learning design researcher,
        course platform builder, and educator at UNC-Chapel Hill, NC State, and UCLA.
      </p>
      <div class="flex gap-4">
        <a href="/learning-design/" class="inline-flex items-center px-5 py-2.5 bg-teal-700 text-white text-sm font-medium rounded-lg hover:bg-teal-800 transition-colors">
          Explore Articles
        </a>
        <a href="/about/" class="inline-flex items-center px-5 py-2.5 border border-stone-300 text-slate-700 text-sm font-medium rounded-lg hover:border-teal-300 hover:text-teal-700 transition-colors">
          About Abe
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Articles -->
  <section class="py-16 sm:py-24">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-sm font-medium text-teal-700 mb-1">Recent</p>
          <h2 class="font-serif text-2xl sm:text-3xl font-bold text-slate-900">Learning Design Research</h2>
        </div>
        <a href="/learning-design/" class="text-sm text-teal-700 hover:underline hidden sm:block">
          View all &rarr;
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={`/learning-design/${article.slug}/`}
            date={article.data.publishDate}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- About callout -->
  <section class="bg-stone-50 border-t border-stone-200 py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-serif text-2xl font-bold text-slate-900 mb-4">About MoreBetterLabs</h2>
      <p class="text-slate-500 leading-relaxed mb-6">
        MoreBetterLabs is a UX research and learning design practice founded by Abe Crystal.
        Our flagship product is <a href="https://www.ruzuku.com" class="text-teal-700 underline decoration-teal-300 hover:decoration-teal-500">Ruzuku</a>,
        an online course platform built from the ground up on learning science principles — serving
        75,000+ courses and 500,000+ students since 2011.
      </p>
      <a href="/about/" class="inline-flex items-center text-sm font-medium text-teal-700 hover:underline">
        Learn more about our work &rarr;
      </a>
    </div>
  </section>
</BaseLayout>
