---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'MoreBetterLabs',
  url: 'https://morebetterlabs.com',
  description: 'Learning design research and practice by Abe Crystal, PhD',
};
---

<BaseLayout
  title="MoreBetterLabs — Learning Design Research & Practice"
  description="Research-backed insights on learning design by Abe Crystal, PhD. How to design online courses that actually work — grounded in learning science, tested in practice."
  canonical="/"
  schema={[websiteSchema]}
>
  <!-- Hero -->
  <section class="pt-20 pb-16 sm:pt-28 sm:pb-20">
    <div class="max-w-[680px] mx-auto px-5">
      <p class="text-sm font-medium mb-5" style="color: hsl(170 60% 50%);">MoreBetterLabs</p>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight mb-6" style="color: hsl(170 5% 95%);">
        Better Learning Design,<br class="hidden sm:block"/> Better Outcomes
      </h1>
      <p class="text-lg leading-relaxed max-w-xl" style="color: hsl(170 5% 55%);">
        Research-backed insights on designing online learning that actually works.
        By <a href="/about/" class="underline underline-offset-3" style="color: hsl(170 60% 60%); text-decoration-color: hsl(170 60% 50% / 0.4);">Abe Crystal, PhD</a> — learning design researcher
        and educator at UNC-Chapel Hill, NC State, and UCLA.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-[680px] mx-auto px-5">
    <div style={`height: 1px; background: hsl(185 8% 14%);`}></div>
  </div>

  <!-- Articles -->
  <section class="py-12 sm:py-16">
    <div class="max-w-[680px] mx-auto px-5">
      <h2 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: hsl(170 60% 50%);">
        Latest Articles
      </h2>
      <div>
        {articles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={`/learning-design/${article.slug}/`}
            date={article.data.publishDate}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- About callout -->
  <section class="py-16 sm:py-20">
    <div class="max-w-[680px] mx-auto px-5">
      <div class="rounded-xl p-8" style={`background: hsl(185 8% 10%); border: 1px solid hsl(185 8% 16%);`}>
        <h2 class="font-serif text-xl font-bold mb-3" style="color: hsl(170 5% 90%);">About MoreBetterLabs</h2>
        <p class="text-sm leading-relaxed mb-4" style="color: hsl(170 5% 50%);">
          MoreBetterLabs is a UX research and learning design practice founded by Abe Crystal.
          Our flagship product is <a href="https://www.ruzuku.com" style="color: hsl(170 60% 60%); text-decoration: underline; text-decoration-color: hsl(170 60% 50% / 0.4); text-underline-offset: 3px;" rel="noopener">Ruzuku</a>,
          an online course platform built from the ground up on learning science — serving
          75,000+ courses and 500,000+ students since 2011.
        </p>
        <a href="/about/" class="text-sm font-medium" style="color: hsl(170 60% 60%);">
          Learn more &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
