---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Learning Design' },
];

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Learning Design for Course Creators',
  description: 'Research-backed articles on learning design by Abe Crystal, PhD.',
  url: 'https://morebetterlabs.com/learning-design/',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: articles.map((article, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: article.data.title,
    url: `https://morebetterlabs.com/learning-design/${article.slug}/`,
  })),
};
---

<BaseLayout
  title="Learning Design for Course Creators | MoreBetterLabs"
  description="Research-backed articles on learning design by Abe Crystal, PhD. Cohort learning, completion rates, adult learning principles, feedback design, and more."
  canonical="/learning-design/"
  schema={[collectionSchema, itemListSchema]}
>
  <section class="pt-20 pb-4 sm:pt-28">
    <div class="max-w-[680px] mx-auto px-5">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="font-serif text-3xl sm:text-4xl font-bold leading-tight mt-6 mb-4" style="color: hsl(170 5% 95%);">
        Learning Design
      </h1>
      <p class="text-lg leading-relaxed" style="color: hsl(170 5% 55%);">
        Research-backed insights on designing online learning that actually works.
      </p>
    </div>
  </section>

  <section class="pb-20 sm:pb-28">
    <div class="max-w-[680px] mx-auto px-5">
      <div>
        {articles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={`/learning-design/${article.slug}/`}
            date={article.data.publishDate}
          />
        ))}
      </div>

      {articles.length === 0 && (
        <p style="color: hsl(170 5% 45%);">Articles coming soon.</p>
      )}
    </div>
  </section>
</BaseLayout>
